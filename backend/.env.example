# SQLite — 파일 기반, 외부 DB 서버 불필요. `npm run db:migrate` 하면 생성됨.
# 경로는 schema.prisma(prisma/) 기준 상대경로 → 실제 파일은 backend/prisma/dev.db.
DATABASE_URL="file:./dev.db"

# App
NODE_ENV=development
PORT=3002

# 자체 발급 JWT (RBAC). 로그인 성공 시 우리가 서명하는 토큰의 비밀키·만료.
# 운영에선 길고 무작위인 값으로 교체하고 .env에만 둔다(커밋 금지).
JWT_SECRET=dev-only-change-me-please-32+chars-secret
JWT_EXPIRES_IN=12h

# Logging
LOG_LEVEL=debug

# Auto-settlement scheduler — fires every N ms.
# Set to 0 to disable (e.g. in tests).
SETTLE_INTERVAL_MS=60000

# Anti-snipe (CUT-5): 마감 임박 입찰 시 마감 자동 연장.
#   ANTISNIPE_WINDOW_MS  마감까지 이 시간 이내 입찰이면 연장 (기본 300000=5분). 0이면 비활성.
#   ANTISNIPE_EXTEND_MS  입찰 시점부터 보장할 잔여 시간 (기본 300000=5분).
ANTISNIPE_WINDOW_MS=300000
ANTISNIPE_EXTEND_MS=300000

# 연말 배당 자동 지급 스케줄 (ADR-008). 기본 비활성 — 실지급은 신중히.
#   DIVIDEND_AUTO_ENABLED      true/1 이면 활성. 컷오프 이후 자동 1회 지급(멱등).
#   DIVIDEND_CHECK_INTERVAL_MS 체크 주기(ms, 기본 3600000=1시간).
#   DIVIDEND_CUTOFF            실행 시작 시각 ISO 오버라이드(데모/테스트용).
#                             미지정 시 올해 12/31 23:59. 예) 2026-12-31T23:59:00
DIVIDEND_AUTO_ENABLED=false
DIVIDEND_CHECK_INTERVAL_MS=3600000
# DIVIDEND_CUTOFF=2026-12-31T23:59:00

# 연말 풀 수집(ADR-017) — REGULAR 미사용 연차를 익년도 1일권 매물로(OP-2/5/6 knob).
#   LEAVEPOOL_START_PRICE    생성 매물 시작가(고정 최소가, 기본 5000)
#   LEAVEPOOL_MIN_INCREMENT  최소 입찰 증분(기본 100)
#   LEAVEPOOL_AUCTION_DAYS   매물당 입찰 기간(일, 기본 7)
#   LEAVEPOOL_WEEKLY_QTY     주당 오픈 개수(0이면 익년도 1/1 전량 동시 시작)
LEAVEPOOL_START_PRICE=5000
LEAVEPOOL_MIN_INCREMENT=100
LEAVEPOOL_AUCTION_DAYS=7
LEAVEPOOL_WEEKLY_QTY=0

# 연말 풀 자동 수집 스케줄(ADR-017, YearEndDividendScheduler와 동일 패턴).
#   LEAVEPOOL_AUTO_ENABLED      true/1 이면 활성. 컷오프 이후 자동 1회 수집(멱등).
#   LEAVEPOOL_CHECK_INTERVAL_MS 체크 주기(ms, 기본 3600000=1시간).
#   LEAVEPOOL_CUTOFF            실행 시작 시각 ISO 오버라이드(데모/테스트용).
#                              미지정 시 올해 12/31 23:59. 예) 2026-12-31T23:59:00
LEAVEPOOL_AUTO_ENABLED=false
LEAVEPOOL_CHECK_INTERVAL_MS=3600000
# LEAVEPOOL_CUTOFF=2026-12-31T23:59:00

# 연말 유찰 재고 영구 삭제(FR-4.2). 컷오프 이후 자동 1회 실행.
#   PURGE_UNSOLD_AUTO_ENABLED      true/1 이면 활성 (기본 비활성 — 영구 삭제는 신중히)
#   PURGE_UNSOLD_CHECK_INTERVAL_MS 체크 주기(ms, 기본 3600000=1시간)
#   PURGE_UNSOLD_CUTOFF            ISO 오버라이드. 기본은 올해 12/31 23:59.
PURGE_UNSOLD_AUTO_ENABLED=false
PURGE_UNSOLD_CHECK_INTERVAL_MS=3600000
# PURGE_UNSOLD_CUTOFF=2026-12-31T23:59:00

# 사내 ezpass 중앙 인증 위임 (ADR-019). 실제 값은 .env 에만.
EZPASS_BASE_URL=https://<ezpass-host>/api/ezpass-backend-cmmn
EZPASS_CMPNY_NO=1
EZPASS_LOCALE=ko
# dev 자체서명 인증서 대응(개발 전용). 운영은 false + 사내 CA 신뢰 설치.
EZPASS_TLS_INSECURE=false
