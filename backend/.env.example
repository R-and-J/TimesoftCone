# MySQL 8 — see docker-compose.yml (local dev)
# 로컬 docker-compose 사용 시 아래 값 그대로. 실제 DB 서버(예: 사내 VM)로
# 연결하려면 backend/.env 에 복사 후 host/port/계정/비번/DB명만 교체.
#   형식: mysql://<user>:<password>@<host>:3306/<database>
DATABASE_URL="mysql://timesoftcone:timesoftcone@localhost:3306/timesoftcone"

# Redis (currently unused; reserved for ADR-006 distributed lock in later PR)
REDIS_URL="redis://localhost:6379"

# App
NODE_ENV=development
PORT=3002

# Logging
LOG_LEVEL=debug

# Auto-settlement scheduler — fires every N ms.
# Set to 0 to disable (e.g. in tests).
SETTLE_INTERVAL_MS=60000

# 사내 ezpass 중앙 인증 위임 (ADR-019). 실제 값은 .env 에만.
EZPASS_BASE_URL=https://<ezpass-host>/api/ezpass-backend-cmmn
EZPASS_CMPNY_NO=1
EZPASS_LOCALE=ko
# dev 자체서명 인증서 대응(개발 전용). 운영은 false + 사내 CA 신뢰 설치.
EZPASS_TLS_INSECURE=false
