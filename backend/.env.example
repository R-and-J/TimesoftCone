# SQLite — 파일 기반, 외부 DB 서버 불필요. `npm run db:migrate` 하면 생성됨.
# 경로는 schema.prisma(prisma/) 기준 상대경로 → 실제 파일은 backend/prisma/dev.db.
DATABASE_URL="file:./dev.db"

# App
NODE_ENV=development
PORT=3002

# 자체 발급 JWT (RBAC). 로그인 성공 시 우리가 서명하는 토큰의 비밀키·만료.
# 운영에선 길고 무작위인 값으로 교체하고 .env에만 둔다(커밋 금지).
JWT_SECRET=dev-only-change-me-please-32+chars-secret
JWT_EXPIRES_IN=12h

# Logging
LOG_LEVEL=debug

# Auto-settlement scheduler — fires every N ms.
# Set to 0 to disable (e.g. in tests).
SETTLE_INTERVAL_MS=60000

# 사내 ezpass 중앙 인증 위임 (ADR-019). 실제 값은 .env 에만.
EZPASS_BASE_URL=https://<ezpass-host>/api/ezpass-backend-cmmn
EZPASS_CMPNY_NO=1
EZPASS_LOCALE=ko
# dev 자체서명 인증서 대응(개발 전용). 운영은 false + 사내 CA 신뢰 설치.
EZPASS_TLS_INSECURE=false
