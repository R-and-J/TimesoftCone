# PostgreSQL — see docker-compose.yml
DATABASE_URL="postgresql://timesoftcone:timesoftcone@localhost:5432/timesoftcone?schema=public"

# Redis (currently unused; reserved for ADR-006 distributed lock in later PR)
REDIS_URL="redis://localhost:6379"

# App
NODE_ENV=development
PORT=3001

# Logging
LOG_LEVEL=debug

# Auto-settlement scheduler — fires every N ms.
# Set to 0 to disable (e.g. in tests).
SETTLE_INTERVAL_MS=60000
