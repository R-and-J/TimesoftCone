// TimesoftCone — schema (SQLite).
// Encodes invariants from CLAUDE.md, ADR-011, ADR-014 (with scope-cuts.md CUT-3).
//
// DB engine: SQLite (file-based, zero external server). The Prisma SQLite
// connector does NOT support `enum` blocks, so the former enums
// (UserRole / Currency / LedgerActionType / AuctionStatus / LeaveType) are
// modeled as String columns. Valid values are enforced two ways:
//   1. domain Value Objects / unions (Currency VO, AuctionStatus, LedgerActionType)
//   2. DB-level CHECK (… IN (…)) constraints in the init migration.
//
// NOTE on autoincrement ids: PKs are `BigInt @default(autoincrement())`, but
// SQLite only auto-assigns an `INTEGER PRIMARY KEY` (rowid alias) — a `BIGINT`
// column is not. The init migration declares those PKs as
// `INTEGER PRIMARY KEY AUTOINCREMENT` (stores 64-bit, read back as BigInt).
// Consequence: `prisma migrate dev` may report drift on the id columns — use
// `migrate deploy` / `migrate reset` (replay the migration as-is), or keep the
// id columns as INTEGER when hand-editing any new migration.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// USERS — minimal stub. Full HR sync is out of scope.
// ─────────────────────────────────────────────────────────────
model User {
  id              BigInt   @id @default(autoincrement())
  empId           String   @unique @map("emp_id")
  name            String
  /// 부서명 (ezpass dept_nm). 신원/조직은 ezpass 기준 (ADR-020).
  team            String?
  /// 직급 (ezpass clsf_nm, 예: 이사/수석/책임). ezpass에서 동기화, 표시용.
  jobRank         String?  @map("job_rank")
  /// 직책 (ezpass ofcsprtps_nm, 예: 본부장/팀장). ezpass에서 동기화, 표시용.
  jobTitle        String?  @map("job_title")
  /// 사내 ezpass 로그인 계정(이메일)과 매핑하기 위한 키. 중앙 인증 위임 시
  /// ezpass의 user_id(이메일)로 이 사용자를 찾는다. (ADR-019)
  email           String?  @unique @map("email")
  /// EMPLOYEE/ADMIN — ezpass 관리자권한(mngrAuthorAt)으로 매 로그인 재동기화 (ADR-020).
  role            String   @default("EMPLOYEE")
  /// 자립형(AUTH_MODE=local) 배포 전용 bcrypt 비밀번호 해시. 위임형(ezpass)에선 null
  /// (비번 검증은 ezpass가 함). (ADR-022)
  passwordHash    String?  @map("password_hash")
  /// 활성 여부. 자립형에서 관리자가 회원을 비활성화하면 false → 로그인 거부. (ADR-022)
  active          Boolean  @default(true)
  /// Annual leave days the user has contributed to the public pool this year.
  /// Drives year-end dividend stake (see GET /api/dividend/me/:userId).
  /// School-project simplification — production would derive this from a
  /// LeavePool aggregate (ADR-017).
  contributedDays  Int      @default(0)  @map("contributed_days")
  createdAt        DateTime @default(now()) @map("created_at")

  wallets       Wallet[]
  ledger        LedgerEntry[]
  bids          BidEvent[]
  wonAuctions   Auction[]      @relation("AuctionWinner")
  leaveBalances LeaveBalance[]
  notifications Notification[]

  @@map("users")
}

// ─────────────────────────────────────────────────────────────
// NOTIFICATION — Observer/Domain-Event 구독 결과물 (ADR-013).
// PlaceBid/SettleAuction이 발행한 이벤트를 NotificationObserver가 받아 적재.
// 핫패스(입찰/정산)는 이 테이블을 직접 모름 — 이벤트 핸들러가 쓴다.
// ─────────────────────────────────────────────────────────────
model Notification {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  /// OUTBID(입찰 밀림) | AUCTION_WON(낙찰).
  type      String
  title     String
  message   String
  auctionId String?  @map("auction_id")
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notification")
}

// ─────────────────────────────────────────────────────────────
// WALLET (ADR-011 master).
// ─────────────────────────────────────────────────────────────
model Wallet {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  currency  String
  balance   BigInt   @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, currency], name: "uq_wallet_user_currency")
  @@map("wallet")
}

// ─────────────────────────────────────────────────────────────
// LEDGER_ENTRY — Insert-Only (CLAUDE.md DB-RULE-1).
// ─────────────────────────────────────────────────────────────
model LedgerEntry {
  id           BigInt          @id @default(autoincrement())
  occurredAt   DateTime        @default(now()) @map("occurred_at")
  userId       BigInt          @map("user_id")
  currency     String
  actionType   String          @map("action_type")
  amount       BigInt
  balanceAfter BigInt          @map("balance_after")
  auctionId    String?         @map("auction_id")
  refNote      String?         @map("ref_note")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, occurredAt])
  @@index([actionType, occurredAt])
  @@map("ledger_entry")
}

// ─────────────────────────────────────────────────────────────
// AUCTION — see scope-cuts.md CUT-3 for why this uses a status
// string instead of the ADR-014 State Pattern.
// ─────────────────────────────────────────────────────────────
model Auction {
  // Human-readable ID ("A-2026-106"). String, not autoinc, so the design
  // canvas mockup data (which uses these IDs) maps 1:1 to the seed.
  id              String         @id
  status          String         @default("CREATED")
  startPrice      BigInt         @map("start_price")
  highest         BigInt
  highestBidder   BigInt?        @map("highest_bidder_id")
  bidCount        Int            @default(0) @map("bid_count")
  minIncrement    BigInt         @default(100) @map("min_increment")
  /// 낙찰자에게 부여하는 AUCTION 연차 일수 (ADR-002 3-flag / CUT-9). 낙찰 정산 시
  /// 우리 leave_balance(AUCTION).adjustedDays 에 적립. ezpass엔 안 보냄(이중보상 방지).
  leaveDays       Int            @default(1) @map("leave_days")
  startedAt       DateTime       @map("started_at")
  endsAt          DateTime       @map("ends_at")
  settledAt       DateTime?      @map("settled_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  winner User?      @relation("AuctionWinner", fields: [highestBidder], references: [id])
  bids   BidEvent[]

  @@index([status, endsAt])
  @@map("auction")
}

// ─────────────────────────────────────────────────────────────
// BID_EVENT — append-only log of accepted bids.
// Separate from ledger_entry: ledger tracks money, bid_event tracks the
// auction action. The ledger has a matching BID row for each accepted bid.
// ─────────────────────────────────────────────────────────────
model BidEvent {
  id        BigInt   @id @default(autoincrement())
  auctionId String   @map("auction_id")
  userId    BigInt   @map("user_id")
  amount    BigInt
  placedAt  DateTime @default(now()) @map("placed_at")

  auction Auction @relation(fields: [auctionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([auctionId, placedAt(sort: Desc)])
  @@map("bid_event")
}

// ─────────────────────────────────────────────────────────────
// LEAVE_BALANCE — leave master is THIS system (ADR-016).
// Structured per user / year / type, modeled on ezpass tbl_user_yryc
// (granted = atmc_yryc_day_qty, adjusted = mdat_yryc_day_qty).
// ADR-002 three-flag separation lives in `leaveType` — only REGULAR is
// wage-eligible / feeds the pool; AUCTION/EVENT stay separate.
// Member identity (name/dept/직급/직책/role) is sourced from ezpass; leave
// balances are owned here so auction settlement stays a single local tx.
// remaining = grantedDays + adjustedDays − usedDays.
// ─────────────────────────────────────────────────────────────
model LeaveBalance {
  id           BigInt    @id @default(autoincrement())
  userId       BigInt    @map("user_id")
  /// 연차년도 (ezpass yryc_year).
  year         Int
  leaveType    String    @map("leave_type")
  /// 자동 부여분 (ezpass atmc_yryc_day_qty).
  grantedDays  Int       @default(0) @map("granted_days")
  /// 조정분 — 경매 낙찰로 획득한 연차가 여기로 적립 (ezpass mdat_yryc_day_qty).
  adjustedDays Int       @default(0) @map("adjusted_days")
  /// 사용분.
  usedDays     Int       @default(0) @map("used_days")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, year, leaveType], name: "uq_leave_user_year_type")
  @@index([userId, year])
  @@map("leave_balance")
}
