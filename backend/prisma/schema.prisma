// TimesoftCone вҖ” schema (SQLite).
// Encodes invariants from CLAUDE.md, ADR-011, ADR-014 (with scope-cuts.md CUT-3).
//
// DB engine: SQLite (file-based, zero external server). The Prisma SQLite
// connector does NOT support `enum` blocks, so the former enums
// (UserRole / Currency / LedgerActionType / AuctionStatus / LeaveType) are
// modeled as String columns. Valid values are enforced two ways:
//   1. domain Value Objects / unions (Currency VO, AuctionStatus, LedgerActionType)
//   2. DB-level CHECK (вҖҰ IN (вҖҰ)) constraints in the init migration.
//
// NOTE on autoincrement ids: PKs are `BigInt @default(autoincrement())`, but
// SQLite only auto-assigns an `INTEGER PRIMARY KEY` (rowid alias) вҖ” a `BIGINT`
// column is not. The init migration declares those PKs as
// `INTEGER PRIMARY KEY AUTOINCREMENT` (stores 64-bit, read back as BigInt).
// Consequence: `prisma migrate dev` may report drift on the id columns вҖ” use
// `migrate deploy` / `migrate reset` (replay the migration as-is), or keep the
// id columns as INTEGER when hand-editing any new migration.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// USERS вҖ” minimal stub. Full HR sync is out of scope.
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model User {
  id              BigInt   @id @default(autoincrement())
  empId           String   @unique @map("emp_id")
  name            String
  /// л¶Җм„ңлӘ… (ezpass dept_nm). мӢ мӣҗ/мЎ°м§ҒмқҖ ezpass кё°мӨҖ (ADR-020).
  team            String?
  /// м§Ғкёү (ezpass clsf_nm, мҳҲ: мқҙмӮ¬/мҲҳм„қ/мұ…мһ„). ezpassм—җм„ң лҸҷкё°нҷ”, н‘ңмӢңмҡ©.
  jobRank         String?  @map("job_rank")
  /// м§Ғмұ… (ezpass ofcsprtps_nm, мҳҲ: ліёл¶ҖмһҘ/нҢҖмһҘ). ezpassм—җм„ң лҸҷкё°нҷ”, н‘ңмӢңмҡ©.
  jobTitle        String?  @map("job_title")
  /// мӮ¬лӮҙ ezpass лЎңк·ёмқё кі„м •(мқҙл©”мқј)кіј л§Өн•‘н•ҳкё° мң„н•ң нӮӨ. мӨ‘м•ҷ мқёмҰқ мң„мһ„ мӢң
  /// ezpassмқҳ user_id(мқҙл©”мқј)лЎң мқҙ мӮ¬мҡ©мһҗлҘј м°ҫлҠ”лӢӨ. (ADR-019)
  email           String?  @unique @map("email")
  /// EMPLOYEE/ADMIN вҖ” мҡ°лҰ¬ мӢңмҠӨн…ңмқҙ мҶҢмң (ADR-020 к°ңм •). мөңмҙҲ н”„лЎңл№„м ҖлӢқ л•Ңл§Ң ezpass
  /// mngrAuthorAtлҘј мҙҲкё° нһҢнҠёлЎң м“°кі , мқҙнӣ„ лЎңк·ёмқё мӢң мһ¬лҸҷкё°нҷ”н•ҳм§Җ м•ҠлҠ”лӢӨ.
  role            String   @default("EMPLOYEE")
  /// мһҗлҰҪнҳ•(AUTH_MODE=local) л°°нҸ¬ м „мҡ© bcrypt л№„л°ҖлІҲнҳё н•ҙмӢң. мң„мһ„нҳ•(ezpass)м—җм„  null
  /// (л№„лІҲ кІҖмҰқмқҖ ezpassк°Җ н•Ё). (ADR-022)
  passwordHash    String?  @map("password_hash")
  /// нҷңм„ұ м—¬л¶Җ. мһҗлҰҪнҳ•м—җм„ң кҙҖлҰ¬мһҗк°Җ нҡҢмӣҗмқ„ л№„нҷңм„ұнҷ”н•ҳл©ҙ false вҶ’ лЎңк·ёмқё кұ°л¶Җ. (ADR-022)
  active          Boolean  @default(true)
  /// Annual leave days the user has contributed to the public pool this year.
  /// Drives year-end dividend stake (see GET /api/dividend/me/:userId).
  /// School-project simplification вҖ” production would derive this from a
  /// LeavePool aggregate (ADR-017).
  contributedDays  Int      @default(0)  @map("contributed_days")
  createdAt        DateTime @default(now()) @map("created_at")

  wallets       Wallet[]
  ledger        LedgerEntry[]
  bids          BidEvent[]
  wonAuctions   Auction[]      @relation("AuctionWinner")
  leaveBalances LeaveBalance[]
  notifications Notification[]
  stakes        Stake[]

  @@map("users")
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// NOTIFICATION вҖ” Observer/Domain-Event кө¬лҸ… кІ°кіјл¬ј (ADR-013).
// PlaceBid/SettleAuctionмқҙ л°ңн–үн•ң мқҙлІӨнҠёлҘј NotificationObserverк°Җ л°ӣм•„ м Ғмһ¬.
// н•«нҢЁмҠӨ(мһ…м°°/м •мӮ°)лҠ” мқҙ н…Ңмқҙлё”мқ„ м§Ғм ‘ лӘЁлҰ„ вҖ” мқҙлІӨнҠё н•ёл“Өлҹ¬к°Җ м“ҙлӢӨ.
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model Notification {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  /// OUTBID(мһ…м°° л°ҖлҰј) | AUCTION_WON(лӮҷм°°) | INVENTORY_CREATED(м—°л§җ н’Җ мҲҳм§‘ вҖ” ADMIN лҢҖмғҒ).
  type      String
  title     String
  message   String
  auctionId String?  @map("auction_id")
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notification")
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// WALLET (ADR-011 master).
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model Wallet {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  currency  String
  balance   BigInt   @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, currency], name: "uq_wallet_user_currency")
  @@map("wallet")
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// LEDGER_ENTRY вҖ” Insert-Only (CLAUDE.md DB-RULE-1).
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model LedgerEntry {
  id           BigInt          @id @default(autoincrement())
  occurredAt   DateTime        @default(now()) @map("occurred_at")
  userId       BigInt          @map("user_id")
  currency     String
  actionType   String          @map("action_type")
  amount       BigInt
  balanceAfter BigInt          @map("balance_after")
  auctionId    String?         @map("auction_id")
  refNote      String?         @map("ref_note")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, occurredAt])
  @@index([actionType, occurredAt])
  @@map("ledger_entry")
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// AUCTION вҖ” see scope-cuts.md CUT-3 for why this uses a status
// string instead of the ADR-014 State Pattern.
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model Auction {
  // Human-readable ID ("A-2026-106"). String, not autoinc, so the design
  // canvas mockup data (which uses these IDs) maps 1:1 to the seed.
  id              String         @id
  status          String         @default("CREATED")
  startPrice      BigInt         @map("start_price")
  highest         BigInt
  highestBidder   BigInt?        @map("highest_bidder_id")
  bidCount        Int            @default(0) @map("bid_count")
  minIncrement    BigInt         @default(100) @map("min_increment")
  /// лӮҷм°°мһҗм—җкІҢ л¶Җм—¬н•ҳлҠ” AUCTION м—°м°Ё мқјмҲҳ (ADR-002 3-flag / CUT-9). лӮҷм°° м •мӮ° мӢң
  /// мҡ°лҰ¬ leave_balance(AUCTION).adjustedDays м—җ м ҒлҰҪ. ezpassм—” м•Ҳ ліҙлғ„(мқҙмӨ‘ліҙмғҒ л°©м§Җ).
  leaveDays       Int            @default(1) @map("leave_days")
  startedAt       DateTime       @map("started_at")
  endsAt          DateTime       @map("ends_at")
  settledAt       DateTime?      @map("settled_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  winner User?      @relation("AuctionWinner", fields: [highestBidder], references: [id])
  bids   BidEvent[]

  @@index([status, endsAt])
  @@map("auction")
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// BID_EVENT вҖ” append-only log of accepted bids.
// Separate from ledger_entry: ledger tracks money, bid_event tracks the
// auction action. The ledger has a matching BID row for each accepted bid.
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model BidEvent {
  id        BigInt   @id @default(autoincrement())
  auctionId String   @map("auction_id")
  userId    BigInt   @map("user_id")
  amount    BigInt
  placedAt  DateTime @default(now()) @map("placed_at")

  auction Auction @relation(fields: [auctionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([auctionId, placedAt(sort: Desc)])
  @@map("bid_event")
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// LEAVE_BALANCE вҖ” leave master is THIS system (ADR-016).
// Structured per user / year / type, modeled on ezpass tbl_user_yryc
// (granted = atmc_yryc_day_qty, adjusted = mdat_yryc_day_qty).
// ADR-002 three-flag separation lives in `leaveType` вҖ” only REGULAR is
// wage-eligible / feeds the pool; AUCTION/EVENT stay separate.
// Member identity (name/dept/м§Ғкёү/м§Ғмұ…/role) is sourced from ezpass; leave
// balances are owned here so auction settlement stays a single local tx.
// remaining = grantedDays + adjustedDays вҲ’ usedDays.
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model LeaveBalance {
  id           BigInt    @id @default(autoincrement())
  userId       BigInt    @map("user_id")
  /// м—°м°Ёл…„лҸ„ (ezpass yryc_year).
  year         Int
  leaveType    String    @map("leave_type")
  /// мһҗлҸҷ л¶Җм—¬л¶„ (ezpass atmc_yryc_day_qty).
  grantedDays  Int       @default(0) @map("granted_days")
  /// мЎ°м •л¶„ вҖ” кІҪл§Ө лӮҷм°°лЎң нҡҚл“қн•ң м—°м°Ёк°Җ м—¬кё°лЎң м ҒлҰҪ (ezpass mdat_yryc_day_qty).
  adjustedDays Int       @default(0) @map("adjusted_days")
  /// мӮ¬мҡ©л¶„.
  usedDays     Int       @default(0) @map("used_days")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, year, leaveType], name: "uq_leave_user_year_type")
  @@index([userId, year])
  @@map("leave_balance")
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// LEAVE_POOL_RUN вҖ” м—°л§җ н’Җ мҲҳм§‘ л°°м№ҳ(ADR-017)мқҳ л©ұл“ұм„ұ/к°җмӮ¬ л§Ҳм»Ө.
// н•ң targetYearм—җ лҢҖн•ҙ 1н–үл§Ң мЎҙмһ¬(UNIQUE) вҶ’ мӨ‘ліө мҲҳм§‘ мӢң л§Өл¬јВ·Stake мӨ‘ліө мғқм„ұ м°ЁлӢЁ.
// idлҠ” BigInt лҢҖмӢ  INTEGER(SQLite autoincrement BigInt л§Ҳмқҙк·ёл Ҳмқҙм…ҳ drift нҡҢн”ј вҖ” ліё нҢҢмқј мғҒлӢЁ мЈјм„қ).
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// STAKE вҖ” м—°лҸ„лі„ л°°лӢ№ м§Җл¶„ мҠӨлғ…мғ·(ADR-017). LeavePool мҲҳм§‘мқҙ (userId, year)лӢ№
// 1н–үмқ„ м Ғмһ¬ вҶ’ л°°лӢ№(ADR-008)мқҙ н•ҙлӢ№ м—°лҸ„мқҳ stakeлҘј мқҪм–ҙ л¶„л°°.
// лӢЁмқј м»¬лҹј user.contributedDaysлҠ” legacy л””мҠӨн”Ңл Ҳмқҙ мҠӨлғ…мғ·мңјлЎңл§Ң лӮЁлҠ”лӢӨ.
// idлҠ” INTEGER(autoincrement BigInt drift нҡҢн”ј вҖ” schema мғҒлӢЁ мЈјм„қ).
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model Stake {
  id        Int      @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  /// мқҙ stakeк°Җ л°ӣлҠ” л°°лӢ№мқҳ м—°лҸ„(= LeavePool мҲҳм§‘мқҳ targetYear).
  year      Int
  days      Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, year], name: "uq_stake_user_year")
  @@index([year])
  @@map("stake")
}

model LeavePoolRun {
  id               Int      @id @default(autoincrement())
  /// мҲҳм§‘ лҢҖмғҒ м—°лҸ„(мқҙ н•ҙмқҳ REGULAR лҜёмӮ¬мҡ©мқ„ м·Ён•©).
  sourceYear       Int      @map("source_year")
  /// мғқм„ұлҗң л§Өл¬јмқҙ мҶҚн•ң м—°лҸ„(= sourceYear + 1). л©ұл“ұ нӮӨ.
  targetYear       Int      @unique @map("target_year")
  contributorCount Int      @map("contributor_count")
  daysCollected    Int      @map("days_collected")
  auctionsCreated  Int      @map("auctions_created")
  status           String   @default("DONE")
  ranAt            DateTime @default(now()) @map("ran_at")

  @@map("leave_pool_run")
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// OUTBOX вҖ” нҠёлһңмһӯм…ҳ м•„мӣғл°•мҠӨ (ADR-005 / ADR-013 мҷёл¶Җнҳём¶ң кІҪлЎң, CUT-4В·7 л¶Җнҷң).
// лӮҷм°° л“ұ лҸ„л©”мқё ліҖкІҪкіј *к°ҷмқҖ нҠёлһңмһӯм…ҳ*м—җм„ң "мҷёл¶Җ HRлЎң ліҙлӮј л©”мӢңм§Җ"лҘј м Ғмһ¬н•ңлӢӨ.
// OutboxRelaySchedulerк°Җ PENDINGмқ„ polling вҶ’ HrLeaveClientлЎң м „мҶЎ, мӢӨнҢЁ мӢң
// м§ҖмҲҳ л°ұмҳӨн”„ мһ¬мӢңлҸ„, maxAttempts мҙҲкіј мӢң DEAD(=DLQ). мҷёл¶Җ мӢңмҠӨн…ң нҳём¶ңмқҖ мқҙ
// кІҪлЎңлЎңл§Ң (in-process EventBusлҠ” н”„лЎңм„ёмҠӨ лӮҙл¶Җ fan-out м „мҡ© вҖ” ADR-013).
// idлҠ” INTEGER(autoincrement BigInt drift нҡҢн”ј вҖ” ліё нҢҢмқј мғҒлӢЁ мЈјм„қ).
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model OutboxMessage {
  id            Int       @id @default(autoincrement())
  topic         String                              // мҳҲ: HR_LEAVE_GRANT
  payload       String                              // JSON л¬ёмһҗм—ҙ
  status        String    @default("PENDING")       // PENDING | SENT | DEAD
  attempts      Int       @default(0)
  maxAttempts   Int       @default(5) @map("max_attempts")
  nextAttemptAt DateTime  @default(now()) @map("next_attempt_at")
  lastError     String?   @map("last_error")
  createdAt     DateTime  @default(now()) @map("created_at")
  sentAt        DateTime? @map("sent_at")

  @@index([status, nextAttemptAt])
  @@map("outbox")
}
