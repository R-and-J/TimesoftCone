// TimesoftCone — schema (SQLite).
// Encodes invariants from CLAUDE.md, ADR-011, ADR-014 (with scope-cuts.md CUT-3).
//
// DB engine: SQLite (file-based, zero external server). The Prisma SQLite
// connector does NOT support `enum` blocks, so the former enums
// (UserRole / Currency / LedgerActionType / AuctionStatus / LeaveType) are
// modeled as String columns. Valid values are enforced two ways:
//   1. domain Value Objects / unions (Currency VO, AuctionStatus, LedgerActionType)
//   2. DB-level CHECK (… IN (…)) constraints in the init migration.
//
// NOTE on autoincrement ids: PKs are `BigInt @default(autoincrement())`, but
// SQLite only auto-assigns an `INTEGER PRIMARY KEY` (rowid alias) — a `BIGINT`
// column is not. The init migration declares those PKs as
// `INTEGER PRIMARY KEY AUTOINCREMENT` (stores 64-bit, read back as BigInt).
// Consequence: `prisma migrate dev` may report drift on the id columns — use
// `migrate deploy` / `migrate reset` (replay the migration as-is), or keep the
// id columns as INTEGER when hand-editing any new migration.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// COMPANY — 멀티테넌시 루트. 회사별 완전 독립 환경(EZPASS 연동사 / EXAM 독립사).
// 모든 테넌트 데이터는 company_id로 스코프된다. super ADMIN(user.companyId=null)만
// 전 회사 통합/스위처로 접근. FK는 마이그레이션에서 부여(스키마는 스칼라만 — 백릴레이션 클러터 회피).
// ─────────────────────────────────────────────────────────────
model Company {
  id        BigInt   @id @default(autoincrement())
  /// 내부 코드: "EZPASS" | "EXAM". UNIQUE.
  code      String   @unique
  name      String
  /// ezpass cmpny_no(연동사). EXAM 등 비연동사는 null.
  cmpnyNo   Int?     @map("cmpny_no")
  /// "EZPASS"(연동) | "EXAM"(독립).
  kind      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("company")
}

// ─────────────────────────────────────────────────────────────
// USERS — minimal stub. Full HR sync is out of scope.
// ─────────────────────────────────────────────────────────────
model User {
  id              BigInt   @id @default(autoincrement())
  empId           String   @unique @map("emp_id")
  name            String
  /// 부서명 (ezpass dept_nm). 신원/조직은 ezpass 기준 (ADR-020).
  team            String?
  /// 직급 (ezpass clsf_nm, 예: 이사/수석/책임). ezpass에서 동기화, 표시용.
  jobRank         String?  @map("job_rank")
  /// 직책 (ezpass ofcsprtps_nm, 예: 본부장/팀장). ezpass에서 동기화, 표시용.
  jobTitle        String?  @map("job_title")
  /// 사내 ezpass 로그인 계정(이메일)과 매핑하기 위한 키. 중앙 인증 위임 시
  /// ezpass의 user_id(이메일)로 이 사용자를 찾는다. (ADR-019)
  email           String?  @unique @map("email")
  /// ADMIN/EZPASS_ADMIN/EXAM_ADMIN/EZPASS/EXAM. 일반(EZPASS/EXAM)은 로그인 시 이메일
  /// 도메인으로 분기(EZPASS_EMAIL_DOMAIN=EZPASS, 그 외=EXAM). 관리자 계열은 고정(강등 안 함).
  /// EZPASS_ADMIN=ezpass 영역, EXAM_ADMIN=exam 영역, ADMIN=최고. DB CHECK로 값 제한.
  role            String   @default("EXAM")
  /// 소속 회사(멀티테넌시). null = super ADMIN(전 회사 통합). 그 외 모든 사용자는 NOT NULL.
  companyId       BigInt?  @map("company_id")
  /// 자립형(AUTH_MODE=local) 배포 전용 bcrypt 비밀번호 해시. 위임형(ezpass)에선 null
  /// (비번 검증은 ezpass가 함). (ADR-022)
  passwordHash    String?  @map("password_hash")
  /// 활성 여부. 자립형에서 관리자가 회원을 비활성화하면 false → 로그인 거부. (ADR-022)
  active          Boolean  @default(true)
  /// Annual leave days the user has contributed to the public pool this year.
  /// Drives year-end dividend stake (see GET /api/dividend/me/:userId).
  /// School-project simplification — production would derive this from a
  /// LeavePool aggregate (ADR-017).
  contributedDays  Int      @default(0)  @map("contributed_days")
  createdAt        DateTime @default(now()) @map("created_at")

  wallets          Wallet[]
  ledger           LedgerEntry[]
  bids             BidEvent[]
  wonAuctions      Auction[]         @relation("AuctionWinner")
  leaveBalances    LeaveBalance[]
  notifications    Notification[]
  stakes           Stake[]
  redemptionOrders     RedemptionOrder[]
  chargeRequests       ChargeRequest[]     @relation("ChargeRequester")
  chargeDecisions      ChargeRequest[]     @relation("ChargeApprover")
  redemptionRequests   RedemptionRequest[] @relation("RedemptionRequester")
  redemptionDecisions  RedemptionRequest[] @relation("RedemptionApprover")

  @@index([companyId])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────
// NOTIFICATION — Observer/Domain-Event 구독 결과물 (ADR-013).
// PlaceBid/SettleAuction이 발행한 이벤트를 NotificationObserver가 받아 적재.
// 핫패스(입찰/정산)는 이 테이블을 직접 모름 — 이벤트 핸들러가 쓴다.
// ─────────────────────────────────────────────────────────────
model Notification {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  /// OUTBID(입찰 밀림) | AUCTION_WON(낙찰) | INVENTORY_CREATED(연말 풀 수집 — ADMIN 대상).
  type      String
  title     String
  message   String
  auctionId String?  @map("auction_id")
  /// 알림 클릭 시 이동할 프론트엔드 경로(예: "/auction/detail/A-2026-110",
  /// "/admin/charges", "/activity"). 백엔드가 알림 만들 때 박고 프론트는 그대로 navigate.
  /// 새 토픽 추가 시 프론트 분기 늘리지 않게 하기 위함.
  linkPath  String?  @map("link_path")
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  companyId BigInt   @default(1) @map("company_id")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([companyId])
  @@map("notification")
}

// ─────────────────────────────────────────────────────────────
// WALLET (ADR-011 master).
// ─────────────────────────────────────────────────────────────
model Wallet {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  currency  String
  balance   BigInt   @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")
  companyId BigInt   @default(1) @map("company_id")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, currency], name: "uq_wallet_user_currency")
  @@index([companyId])
  @@map("wallet")
}

// ─────────────────────────────────────────────────────────────
// LEDGER_ENTRY — Insert-Only (CLAUDE.md DB-RULE-1).
// ─────────────────────────────────────────────────────────────
model LedgerEntry {
  id           BigInt          @id @default(autoincrement())
  occurredAt   DateTime        @default(now()) @map("occurred_at")
  userId       BigInt          @map("user_id")
  currency     String
  actionType   String          @map("action_type")
  amount       BigInt
  balanceAfter BigInt          @map("balance_after")
  auctionId    String?         @map("auction_id")
  refNote      String?         @map("ref_note")
  companyId    BigInt          @default(1) @map("company_id")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, occurredAt])
  @@index([actionType, occurredAt])
  @@index([companyId, actionType])
  @@map("ledger_entry")
}

// ─────────────────────────────────────────────────────────────
// AUCTION — see scope-cuts.md CUT-3 for why this uses a status
// string instead of the ADR-014 State Pattern.
// ─────────────────────────────────────────────────────────────
model Auction {
  // Human-readable ID ("A-2026-106"). String, not autoinc, so the design
  // canvas mockup data (which uses these IDs) maps 1:1 to the seed.
  id              String         @id
  status          String         @default("CREATED")
  startPrice      BigInt         @map("start_price")
  highest         BigInt
  highestBidder   BigInt?        @map("highest_bidder_id")
  bidCount        Int            @default(0) @map("bid_count")
  minIncrement    BigInt         @default(100) @map("min_increment")
  /// 낙찰자에게 부여하는 AUCTION 연차 일수 (ADR-002 3-flag / CUT-9). 낙찰 정산 시
  /// 우리 leave_balance(AUCTION).adjustedDays 에 적립. ezpass엔 안 보냄(이중보상 방지).
  leaveDays       Int            @default(1) @map("leave_days")
  startedAt       DateTime       @map("started_at")
  endsAt          DateTime       @map("ends_at")
  settledAt       DateTime?      @map("settled_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  companyId       BigInt         @default(1) @map("company_id")

  winner User?      @relation("AuctionWinner", fields: [highestBidder], references: [id])
  bids   BidEvent[]

  @@index([status, endsAt])
  @@index([companyId, status])
  @@map("auction")
}

// ─────────────────────────────────────────────────────────────
// BID_EVENT — append-only log of accepted bids.
// Separate from ledger_entry: ledger tracks money, bid_event tracks the
// auction action. The ledger has a matching BID row for each accepted bid.
// ─────────────────────────────────────────────────────────────
model BidEvent {
  id        BigInt   @id @default(autoincrement())
  auctionId String   @map("auction_id")
  userId    BigInt   @map("user_id")
  amount    BigInt
  placedAt  DateTime @default(now()) @map("placed_at")

  companyId BigInt   @default(1) @map("company_id")

  auction Auction @relation(fields: [auctionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([auctionId, placedAt(sort: Desc)])
  @@index([companyId])
  @@map("bid_event")
}

// ─────────────────────────────────────────────────────────────
// LEAVE_BALANCE — leave master is THIS system (ADR-016).
// Structured per user / year / type, modeled on ezpass tbl_user_yryc
// (granted = atmc_yryc_day_qty, adjusted = mdat_yryc_day_qty).
// ADR-002 three-flag separation lives in `leaveType` — only REGULAR is
// wage-eligible / feeds the pool; AUCTION/EVENT stay separate.
// Member identity (name/dept/직급/직책/role) is sourced from ezpass; leave
// balances are owned here so auction settlement stays a single local tx.
// remaining = grantedDays + adjustedDays − usedDays.
// ─────────────────────────────────────────────────────────────
model LeaveBalance {
  id           BigInt    @id @default(autoincrement())
  userId       BigInt    @map("user_id")
  /// 연차년도 (ezpass yryc_year).
  year         Int
  leaveType    String    @map("leave_type")
  /// 자동 부여분 (ezpass atmc_yryc_day_qty).
  grantedDays  Int       @default(0) @map("granted_days")
  /// 조정분 — 경매 낙찰로 획득한 연차가 여기로 적립 (ezpass mdat_yryc_day_qty).
  adjustedDays Int       @default(0) @map("adjusted_days")
  /// 사용분.
  usedDays     Int       @default(0) @map("used_days")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  companyId    BigInt    @default(1) @map("company_id")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, year, leaveType], name: "uq_leave_user_year_type")
  @@index([userId, year])
  @@index([companyId])
  @@map("leave_balance")
}

// ─────────────────────────────────────────────────────────────
// LEAVE_POOL_RUN — 연말 풀 수집 배치(ADR-017)의 멱등성/감사 마커.
// 한 targetYear에 대해 1행만 존재(UNIQUE) → 중복 수집 시 매물·Stake 중복 생성 차단.
// id는 BigInt 대신 INTEGER(SQLite autoincrement BigInt 마이그레이션 drift 회피 — 본 파일 상단 주석).
// ─────────────────────────────────────────────────────────────
// ─────────────────────────────────────────────────────────────
// STAKE — 연도별 배당 지분 스냅샷(ADR-017). LeavePool 수집이 (userId, year)당
// 1행을 적재 → 배당(ADR-008)이 해당 연도의 stake를 읽어 분배.
// 단일 컬럼 user.contributedDays는 legacy 디스플레이 스냅샷으로만 남는다.
// id는 INTEGER(autoincrement BigInt drift 회피 — schema 상단 주석).
// ─────────────────────────────────────────────────────────────
model Stake {
  id        Int      @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  /// 이 stake가 받는 배당의 연도(= LeavePool 수집의 targetYear).
  year      Int
  days      Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  companyId BigInt   @default(1) @map("company_id")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, year], name: "uq_stake_user_year")
  @@index([companyId, year])
  @@map("stake")
}

model LeavePoolRun {
  id               Int      @id @default(autoincrement())
  /// 수집 대상 연도(이 해의 REGULAR 미사용을 취합).
  sourceYear       Int      @map("source_year")
  /// 생성된 매물이 속한 연도(= sourceYear + 1). 회사별 멱등 키.
  targetYear       Int      @map("target_year")
  companyId        BigInt   @default(1) @map("company_id")
  contributorCount Int      @map("contributor_count")
  daysCollected    Int      @map("days_collected")
  auctionsCreated  Int      @map("auctions_created")
  status           String   @default("DONE")
  ranAt            DateTime @default(now()) @map("ran_at")

  // 멀티테넌시: 멱등 키를 (회사, targetYear)로 — 회사별로 같은 연도를 독립 수집.
  @@unique([companyId, targetYear], name: "uq_pool_company_target")
  @@map("leave_pool_run")
}

// ─────────────────────────────────────────────────────────────
// OUTBOX — 트랜잭션 아웃박스 (ADR-005 / ADR-013 외부호출 경로, CUT-4·7 부활).
// 낙찰 등 도메인 변경과 *같은 트랜잭션*에서 "외부 HR로 보낼 메시지"를 적재한다.
// OutboxRelayScheduler가 PENDING을 polling → HrLeaveClient로 전송, 실패 시
// 지수 백오프 재시도, maxAttempts 초과 시 DEAD(=DLQ). 외부 시스템 호출은 이
// 경로로만 (in-process EventBus는 프로세스 내부 fan-out 전용 — ADR-013).
// id는 INTEGER(autoincrement BigInt drift 회피 — 본 파일 상단 주석).
// ─────────────────────────────────────────────────────────────
model OutboxMessage {
  id            Int       @id @default(autoincrement())
  topic         String                              // 예: HR_LEAVE_GRANT
  payload       String                              // JSON 문자열
  status        String    @default("PENDING")       // PENDING | SENT | DEAD
  attempts      Int       @default(0)
  maxAttempts   Int       @default(5) @map("max_attempts")
  nextAttemptAt DateTime  @default(now()) @map("next_attempt_at")
  lastError     String?   @map("last_error")
  createdAt     DateTime  @default(now()) @map("created_at")
  sentAt        DateTime? @map("sent_at")
  companyId     BigInt    @default(1) @map("company_id")

  @@index([status, nextAttemptAt])
  @@index([companyId])
  @@map("outbox")
}

// ─────────────────────────────────────────────────────────────
// REDEMPTION_ITEM — 자립형 배포의 포인트 소모처 상품 카탈로그 (ADR-023).
// 위임형(기본)에선 미사용. AI 구독권/식권/카페 상품권 등.
// id는 INTEGER(autoincrement BigInt drift 회피 — 본 파일 상단 주석).
// ─────────────────────────────────────────────────────────────
model RedemptionItem {
  id          Int      @id @default(autoincrement())
  companyId   BigInt   @default(1) @map("company_id")
  sku         String   @unique
  name        String
  description String?
  /// 1개 교환 시 차감되는 포인트.
  priceP      BigInt   @map("price_p")
  /// 재고. null이면 무제한.
  stock       Int?
  active      Boolean  @default(true)
  /// UI 카테고리 라벨(예: "디지털 구독", "식권", "상품권").
  category    String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  orders   RedemptionOrder[]
  requests RedemptionRequest[]

  @@index([active, category])
  @@map("redemption_item")
}

// ─────────────────────────────────────────────────────────────
// REDEMPTION_ORDER — 교환 1건 (사용자가 상품 1개를 포인트로 받음).
// 같은 트랜잭션에서 redemption_item.stock - 1, wallet 차감, ledger(REDEEM) INSERT,
// 그리고 이 행 INSERT가 한꺼번에 일어남. status는 발송 진행을 추적
// (PENDING → FULFILLED|FAILED|REFUNDED). 내부 카탈로그는 즉시 FULFILLED.
// ─────────────────────────────────────────────────────────────
model RedemptionOrder {
  id             Int      @id @default(autoincrement())
  userId         BigInt   @map("user_id")
  itemId         Int      @map("item_id")
  /// 교환 시점의 가격 스냅샷(상품 가격이 나중에 바뀌어도 주문엔 그대로).
  pricePAtRedeem BigInt   @map("price_p_at_redeem")
  /// PENDING | FULFILLED | FAILED | REFUNDED.
  status         String   @default("PENDING")
  /// 발송 채널 참조(예: 쿠폰 코드, 외부 API tx id).
  deliveryRef    String?  @map("delivery_ref")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  companyId      BigInt   @default(1) @map("company_id")

  user User           @relation(fields: [userId], references: [id])
  item RedemptionItem @relation(fields: [itemId], references: [id])

  @@index([userId, createdAt])
  @@index([companyId])
  @@map("redemption_order")
}

// ─────────────────────────────────────────────────────────────
// REDEMPTION_REQUEST — 사용자 주도 교환 신청, 관리자 승인+쿠폰 발급, 사용자 수령 컨펌.
// 흐름: PENDING(차감/잠금) → APPROVED(couponCode 발급) → RECEIVED(사용자 확정)
//                       ↘ REJECTED(REDEEM_REFUND 보상)
// 차감 시점은 신청 — 잔액·재고 잠금이 ADR-001 escrow 모델과 정합.
// 즉시 결제(RedemptionOrder)는 더 이상 신규 흐름 아님 — 옛 데이터는 그대로 보존.
// ─────────────────────────────────────────────────────────────
model RedemptionRequest {
  id              Int       @id @default(autoincrement())
  userId          BigInt    @map("user_id")
  itemId          Int       @map("item_id")
  /// 신청 시점의 가격 스냅샷(이후 priceP가 바뀌어도 신청 건은 그대로).
  pricePAtRequest BigInt    @map("price_p_at_request")
  /// 사용자 메모(선택 — 배송지/특이사항/사이즈 등).
  note            String?
  /// PENDING | APPROVED | RECEIVED | REJECTED.
  status          String    @default("PENDING")
  /// 관리자가 승인 시 발급한 쿠폰코드/링크/안내문(그냥 텍스트).
  couponCode      String?   @map("coupon_code")
  /// 결정한 관리자(승인·반려).
  decidedBy       BigInt?   @map("decided_by")
  decidedAt       DateTime? @map("decided_at")
  /// 관리자 결정 사유(주로 REJECTED).
  decisionNote    String?   @map("decision_note")
  /// 사용자가 "수령 완료" 버튼을 누른 시각(RECEIVED).
  receivedAt      DateTime? @map("received_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  companyId       BigInt    @default(1) @map("company_id")

  user          User           @relation("RedemptionRequester", fields: [userId], references: [id])
  decidedByUser User?          @relation("RedemptionApprover", fields: [decidedBy], references: [id])
  item          RedemptionItem @relation(fields: [itemId], references: [id])

  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@index([companyId, status])
  @@map("redemption_request")
}

// ─────────────────────────────────────────────────────────────
// CHARGE_REQUEST — 사용자 주도 충전 요청, 관리자 승인 워크플로 (ADR-024).
// 사용자: PENDING 등록 → 관리자: APPROVED(같은 tx에 CreditWalletAdmin 실행)
// 또는 REJECTED. 결정 이벤트가 NotificationObserver에 도달해 양방향 알림.
// ─────────────────────────────────────────────────────────────
model ChargeRequest {
  id           Int       @id @default(autoincrement())
  userId       BigInt    @map("user_id")
  amount       BigInt
  /// 사용자 요청 사유(선택).
  note         String?
  /// PENDING | APPROVED | REJECTED.
  status       String    @default("PENDING")
  /// 결정한 관리자.
  decidedBy    BigInt?   @map("decided_by")
  decidedAt    DateTime? @map("decided_at")
  /// 관리자 결정 사유(주로 REJECTED).
  decisionNote String?   @map("decision_note")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  companyId    BigInt    @default(1) @map("company_id")

  user          User  @relation("ChargeRequester", fields: [userId], references: [id])
  decidedByUser User? @relation("ChargeApprover", fields: [decidedBy], references: [id])

  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@index([companyId, status])
  @@map("charge_request")
}

// ─────────────────────────────────────────────────────────────
// RELEASE_POLICY — 풀 수집된 매물의 startedAt 분산 정책(싱글톤).
// LeavePool 수집(ADR-017) 이후 생성되는 CREATED 매물을
// "daily / weekly(요일) / monthly(일)" + 시각 + 1회 수량 으로 분산.
// 관리자가 수동 PATCH로 갱신 → 다음 수집 또는 재분산에 즉시 반영.
// 행은 단 하나(id=1)만 존재(애플리케이션 보장). 환경변수 폴백은 시드에서 부여.
// id INTEGER(autoincrement BigInt drift 회피 — 본 파일 상단 주석).
// ─────────────────────────────────────────────────────────────
model ReleasePolicy {
  id          Int      @id @default(1)
  /// 멀티테넌시 컬럼(중간단계: 싱글톤 유지, 회사 스코프는 후속). 기본 1(EZPASS).
  companyId   BigInt   @default(1) @map("company_id")
  /// "none" | "daily" | "weekly" | "monthly". none = 자동 분산 비활성.
  cadence     String
  /// weekly 일 때 0(일)~6(토). 그 외 cadence엔 무시.
  dayOfWeek   Int?     @map("day_of_week")
  /// monthly 일 때 1..31. 31이면 짧은 달은 EOM 폴백.
  dayOfMonth  Int?     @map("day_of_month")
  /// "HH:MM" 24h. none이면 null.
  timeOfDay   String?  @map("time_of_day")
  /// 1회 발행 시 오픈할 매물 수. none이면 null.
  quantity    Int?
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("release_policy")
}
