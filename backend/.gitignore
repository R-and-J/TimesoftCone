# Dependencies
node_modules/

# Build output
dist/
build/

# NestJS
.nest/

# TypeScript
*.tsbuildinfo

# Test / coverage
coverage/
.nyc_output/

# Env (루트 .gitignore와 중복이나, 폴더 단독 사용 대비)
.env
.env.*
!.env.example

# Logs
*.log
logs/

# Lint cache
.eslintcache

# Prisma SQLite — sidecar/journal 은 커밋 금지
prisma/*.db-journal
prisma/*.db-wal
prisma/*.db-shm
# dev.db 는 팀 공유 시드로 *커밋한다* (테스트 데이터, PII 없음).
# 규칙: 단일 소유자만 커밋. 받는 쪽은 클론 후 한 번만 실행 —
#   git update-index --skip-worktree backend/prisma/dev.db
prisma/*.db
!prisma/dev.db
# 로컬 시드 스냅샷(db:snapshot/restore) — 개발자 PC 한정, 공유 X
prisma/dev.db.snapshot

# Docker 로컬 볼륨
docker-data/
pgdata/

# 사내 ezpass msaportal DB 조사/이식 스크립트 — 접속정보(mammoth) 하드코딩, 커밋 금지
scripts/
